# =============================================================================
# Conexão com o Supabase
# =============================================================================
# Pegue em: Project Settings → Database → Connection string (URI)
# Use o "Session pooler" (porta 5432) — funciona com prepared statements.
# Senha é a do banco (não é a anon key).
DATABASE_URL=postgresql+psycopg://postgres.SEU_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Project Settings → API
SUPABASE_URL=https://SEU_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # NUNCA exponha pro frontend
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui   # Project Settings → API → JWT Settings

# =============================================================================
# Aplicação
# =============================================================================
ENV=development                   # development | production
LOG_LEVEL=INFO

# CORS — domínios permitidos, separados por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
